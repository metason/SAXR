{
	"$schema": "../../schemas/config.json",
	"description": "3D data viz of Iris data set.",
	"title": "Iris",
	"stage": {
		"width": 0.8,
		"height": 0.8,
		"depth": 0.8
	},
	"data": {
		"url": "../iris/iris.json"
	},
	"assetURL": "https://service.metason.net/ar/content/viz/cluster/",
	"gridColor": "#DDDE00",
	"bgColor": "#FFFFFF",
	"plot": "cluster",
	"mark": "sphere",
	"encoding": {
		"x": {
			"field": "sepal width"
		},
		"y": {
			"field": "petal length"
		},
		"z": {
			"field": "petal width"
		},
		"size": {
			"value": 0.018
		},
		"color": {
			"field": "class",
			"title": "Iris Classes"
		}
	},
	"panels": ["xy+s", "-xy+s", "zy+s", "-zy+s", "xz+s", "lc=_"]
}
