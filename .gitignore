# ========================
# Unity - Ignore
# ========================
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/
AssetStoreTools/

# Autogenerated Crash Reports
sysinfo.txt
crashlytics-build.properties

# Unity3D generated file on crash reports
*.stackdump

# Packed scene files (force text serialization instead)
# *.unity is NOT ignored — you need scene files in version control

# ========================
# Unity - KEEP (do NOT ignore)
# ========================
# .meta files — CRITICAL for Unity collaboration
# If a .meta file is missing, Unity reassigns GUIDs and breaks references
# !/[Aa]ssets/**/*.meta  ← not needed, they are tracked by default

# ProjectSettings/ — KEEP (shared project config)
# Packages/ — KEEP (package manifest)

# ========================
# IDE
# ========================
.vs/
.vscode/
*.suo
*.user
*.pidb
*.booproj
*.svd
*.pdb
*.opendb
*.VC.db

# .csproj and .sln are auto-generated by Unity.
# Unity regenerates them on open, so they can safely be ignored.
*.csproj
*.sln

# JetBrains Rider
.idea/
*.DotSettings.user

# ========================
# OS
# ========================
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db

# ========================
# Python
# ========================
__pycache__/
*.pyc
*.pyo
.env
venv/
.venv/
*.egg-info/
.pytest_cache/

# ========================
# Generated sample outputs
# ========================
# These are produced by datarepgen.py / export3D.py and can be regenerated.
samples/*/datareps.json
samples/*/specs.json
samples/*/*.png
samples/*/result3D/

# Source PNGs that are NOT generated — keep tracked
!samples/eco/CNflag.png
!samples/eco/EUflag.png
!samples/eco/USflag.png
!samples/geo/map.png

# ========================
# Build outputs
# ========================
*.apk
*.aab
*.unitypackage
*.app
*.exe
*.zip
